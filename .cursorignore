# ── 依賴與建置產物（最大宗，優先排除）────────────────────────
backend/venv/
**/.venv/
frontend/node_modules/
frontend/dist/

# Git / LFS 物件（~850 MB+）
.git/

# 舊版重複 checkout（~1.1 GB）
EchoWing-Backend/

