# 本地資料目錄（保留空目錄結構）
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# 虛擬環境（根目錄 .gitignore 亦涵蓋）
venv/
.venv/

# 環境設定
.env

# 大型模型權重 — HF 部署請用 Git LFS（見 .gitattributes、DEPLOY_HF.md）
models/*
!models/.gitkeep
!models/pseudo_best_model.pt
!models/perch_v2_cpu_savedmodel/
!models/perch_v2_cpu_savedmodel/**
!models/taxonomy.csv
!models/taxonomy_processed.csv
!models/species_info_completed_comma.csv
!models/val_line.json
!models/resnet18_v3_int8.onnx
